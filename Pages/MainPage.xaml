<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="calories_tracker.Pages.MainPage">

    <VerticalStackLayout 
        Spacing="25" 
        Padding="30" 
        VerticalOptions="Center" 
        HorizontalOptions="Center">

        <Label 
            Text="Scanner Prodotti"
            FontSize="32"
            FontAttributes="Bold"
            HorizontalOptions="Center" />

        <Label 
            Text="Premi il pulsante qui sotto per inquadrare il codice a barre sull'etichetta."
            FontSize="16"
            HorizontalOptions="Center" 
            HorizontalTextAlignment="Center"/>

        <Button 
            x:Name="BtnFotocamera"
            Text="Scansiona Alimenti"
            FontSize="18"
            CornerRadius="10"
            Padding="20,15"
            Clicked="OnBtnFotocameraClicked"
            HorizontalOptions="Center" />

    </VerticalStackLayout>

</ContentPage>